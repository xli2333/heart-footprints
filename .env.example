# 模块一：我们的暗号 (Our Secret Codes)
USER_HIM_PASSWORD=your_secret_password_here
USER_HER_PASSWORD=her_secret_password_here
USER_HIM_NAME=你的昵称
USER_HER_NAME=她的昵称

# JWT 会话加密密钥 (建议使用强随机字符串)
JWT_SECRET=your_very_long_and_random_jwt_secret_key_here

# Supabase 配置 (在 Supabase 项目的 Settings -> API 中找到)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# 地图服务配置 (Mapbox)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_access_token

# 应用基本配置
NEXT_PUBLIC_APP_URL=http://localhost:3000